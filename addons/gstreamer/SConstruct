#!/usr/bin/env python

import os

env = SConscript("godot-cpp/SConstruct")

# GStreamer include paths and link flags via pkg-config
env.ParseConfig("pkg-config --cflags --libs gstreamer-1.0 gstreamer-app-1.0 gstreamer-video-1.0")

# Source directory
env.Append(CPPPATH=["src/"])
sources = Glob("src/*.cpp")

# Build shared library
library = env.SharedLibrary(
    "bin/libgstreamer_godot{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
    source=sources,
)

Default(library)
