[configuration]
entry_symbol = "gstreamer_library_init"
compatibility_minimum = "4.2"
reloadable = true

[libraries]
linux.editor.x86_64 = "res://addons/gstreamer/bin/libgstreamer_godot.linux.template_debug.x86_64.so"
linux.debug.x86_64 = "res://addons/gstreamer/bin/libgstreamer_godot.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/gstreamer/bin/libgstreamer_godot.linux.template_release.x86_64.so"
linux.template_debug.x86_64 = "res://addons/gstreamer/bin/libgstreamer_godot.linux.template_debug.x86_64.so"
linux.template_release.x86_64 = "res://addons/gstreamer/bin/libgstreamer_godot.linux.template_release.x86_64.so"
android.debug.arm64 = "res://addons/gstreamer/bin/libgstreamer_godot.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/gstreamer/bin/libgstreamer_godot.android.template_release.arm64.so"
android.template_debug.arm64 = "res://addons/gstreamer/bin/libgstreamer_godot.android.template_debug.arm64.so"
android.template_release.arm64 = "res://addons/gstreamer/bin/libgstreamer_godot.android.template_release.arm64.so"
