; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Quest3"
run/main_scene="res://scenes/StereoViewScene.tscn"
; FIX: "Forward Plus" → "Mobile" — Android / Quest cihazlarda Forward Plus
; ExternalTexture GL id'sini geçersiz kılıyor ve siyah ekrana yol açıyor.
; Mobile renderer Vulkan mobile / GLES3 ile çalışır ve ExternalTexture'ı destekler.
config/features=PackedStringArray("4.6", "C#", "Mobile")
config/icon="res://icon.svg"

[dotnet]

project/assembly_name="Quest3"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

; FIX: d3d12 Windows geliştirme ortamı içindi, Android'de sorun çıkarabilir.
; Yorum satırı yapıldı — Godot Android'de otomatik Vulkan/GLES3 seçer.
; rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
textures/vram_compression/import_etc2_astc=true
